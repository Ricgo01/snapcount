NEXT_PUBLIC_SUPABASE_URL=example_url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=example_key
SUPABASE_SECRET_KEY=example_secret_key

# Secret that protects /api/refresh and the /api/backfill* endpoints.
# Generate with: openssl rand -hex 32
CRON_SECRET=example_cron_secret

# Public URL of the deployed app — used for SEO (sitemap, robots, canonical/OG)
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Upstash Redis — per-IP rate limiting in proxy.ts (free tier: console.upstash.com).
# Optional: without these vars the rate limiter fails open (no limiting).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
